{
  "name": "do_while_list_iteration_http",
  "description": "Test DO_WHILE with list iteration using HTTP task (Issue #582 example)",
  "version": 1,
  "tasks": [
    {
      "name": "do_while",
      "taskReferenceName": "do_while_ref",
      "inputParameters": {},
      "type": "DO_WHILE",
      "items": "${workflow.input.items}",
      "loopOver": [
        {
          "name": "http",
          "taskReferenceName": "http_ref",
          "inputParameters": {
            "http_request": {
              "uri": "https://orkes-api-tester.orkesconductor.com/api",
              "method": "GET",
              "accept": "application/json",
              "contentType": "application/json",
              "body": {
                "item": "${do_while_ref.output.loopItem}"
              }
            }
          },
          "type": "HTTP"
        }
      ]
    }
  ],
  "schemaVersion": 2,
  "ownerEmail": "test@example.com"
}
